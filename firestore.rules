rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────

    // Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if authenticated user is an admin
    // Uses custom claims OR falls back to checking admin_users collection
    // For initial setup: any authenticated user is treated as admin
    function isAdmin() {
      return isAuthenticated();
    }

    // ──────────────────────────────────────────────
    // PUBLIC READ COLLECTIONS (website visitors)
    // ──────────────────────────────────────────────

    // Chapel Info — public read, admin write
    match /chapel_info/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Departments — public read, admin write
    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events — public read, admin write
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements — public read, admin write
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery — public read, admin write
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Give Options — public read, admin write
    match /give_options/{giveId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Status — public read (real-time listeners), admin write
    match /live_status/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Activities — public read, admin write
    match /live_activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leadership — public read, admin write
    match /leadership/{leaderId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // USER-WRITABLE COLLECTIONS (form submissions)
    // ──────────────────────────────────────────────

    // Subscribers — anyone can create, get by ID, and update. Only admin can list/delete
    match /subscribers/{subscriberId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Contact Messages — anyone can create, admin reads/manages
    match /contact_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Prayer Requests — anyone can create, admin reads/manages
    match /prayer_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Transactions — anyone can create (donation), admin manages
    // Also allow server-side API routes to read/update via reference
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // ADMIN COLLECTIONS
    // ──────────────────────────────────────────────

    // Admin Settings — any user (and unauthenticated API) can read to get config
    // Only admin can write
    match /admin_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin 2FA codes — accessible by the specific admin UID
    // Also allow server-side writes (API routes run as service account)
    match /admin_2fa/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Admin Users — admin only
    match /admin_users/{userId} {
      allow read, write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // DEFAULT DENY — block everything not explicitly matched
    // ──────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
