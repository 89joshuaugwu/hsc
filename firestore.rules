rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────

    // Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user is an admin
    // Admin is determined by custom claims or presence in admin_users collection
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ──────────────────────────────────────────────
    // PUBLIC READ COLLECTIONS (website visitors)
    // ──────────────────────────────────────────────

    // Chapel Info — public read, admin write
    match /chapel_info/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Departments — public read active, admin full access
    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events — public read active, admin full access
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements — public read active, admin full access
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery — public read, admin full access
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Give Options — public read active, admin full access
    match /give_options/{giveId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Status — public read (real-time listeners), admin write
    match /live_status/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Activities — public read, admin write
    match /live_activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // USER-WRITABLE COLLECTIONS (form submissions)
    // ──────────────────────────────────────────────

    // Subscribers — anyone can create, admin reads/updates
    match /subscribers/{subscriberId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Contact Messages — anyone can create, admin reads/manages
    match /contact_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Prayer Requests — anyone can create, admin reads/manages
    match /prayer_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Transactions — anyone can create (donation), admin manages
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // ADMIN-ONLY COLLECTIONS
    // ──────────────────────────────────────────────

    // Admin Settings — admin only
    match /admin_settings/{docId} {
      allow read, write: if isAdmin();
    }

    // Admin 2FA codes — locked to the specific admin UID
    match /admin_2fa/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Admin Users — admin only
    match /admin_users/{userId} {
      allow read, write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // DEFAULT DENY — block everything not explicitly matched
    // ──────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
